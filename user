# Función de verificación forzada
force_verification() {
    clear
    echo -e "${cor[cyan]}╔════════════════════════════════════════════════════╗${cor[reset]}"
    echo -e "${cor[cyan]}║      $(fun_trans 'VERIFICACIÓN MANUAL')                 ║${cor[reset]}"
    echo -e "${cor[cyan]}╚════════════════════════════════════════════════════╝${cor[reset]}"
    msg_bar
    
    echo -e "${cor[yellow]}$(fun_trans 'Ejecutando verificación manual...')${cor[reset]}"
    
    local TimeNOW=$(date +%s)
    local expired_count=0
    
    # Verificar expirados
    while read user; do
        local DataUser=$(get_user_expiry "$user")
        [[ -z "$DataUser" ]] || [[ "$DataUser" == "never" ]] && continue
        local DataSEC=$(date +%s --date="$DataUser" 2>/dev/null)
        if [[ "$DataSEC" -lt "$TimeNOW" ]]; then
            usermod -L "$user" 2>/dev/null
            expired_count=$((expired_count + 1))
            echo -e "${cor[red]}✘ $(fun_trans 'Usuario expirado') $user${cor[reset]}"
        fi
    done <<< "$(mostrar_usuarios)"
    
    # Verificar límites
    local limit_violations=0
    while read user; do
        local TotalPID=$(get_user_connections "$user")
        if [[ "$TotalPID" -gt 0 ]]; then
            local info=$(get_user_info "$user")
            local limit=$(echo "$info" | cut -d'|' -f4)
            if [[ -n "$limit" ]] && [[ "$limit" =~ ^[0-9]+$ ]] && [[ "$TotalPID" -gt "$limit" ]]; then
                local kill_count=$((TotalPID - limit))
                local pids=$(ps aux 2>/dev/null | grep -v grep | grep -E "(sshd|dropbear|openvpn)" | grep -w "$user" | awk '{print $2}' | tail -n "$kill_count")
                for pid in $pids; do
                    kill -9 "$pid" 2>/dev/null
                done
                usermod -L "$user" 2>/dev/null
                limit_violations=$((limit_violations + 1))
                echo -e "${cor[red]}✘ $(fun_trans 'Límite excedido') $user (${TotalPID}/${limit})${cor[reset]}"
            fi
        fi
    done <<< "$(mostrar_usuarios)"
    
    msg_bar
    echo -e "${cor[cyan]}╔═══════════════════════════════════════════╗${cor[reset]}"
    echo -e "${cor[cyan]}║      $(fun_trans 'RESUMEN DE VERIFICACIÓN')        ║${cor[reset]}"
    echo -e "${cor[cyan]}╚═══════════════════════════════════════════╝${cor[reset]}"
    echo -e "${cor[yellow]}➤ $(fun_trans 'Usuarios expirados'): ${cor[red]}$expired_count${cor[reset]}"
    echo -e "${cor[yellow]}➤ $(fun_trans 'Violaciones de límite'): ${cor[red]}$limit_violations${cor[reset]}"
    echo -e "${cor[yellow]}➤ $(fun_trans 'Usuarios activos'): ${cor[green]}$(ps aux 2>/dev/null | grep -E "(sshd|dropbear|openvpn)" | grep -v grep | awk '{print $1}' | sort -u | wc -l)${cor[reset]}"
    
    log_user_action "FORCE_VERIFICATION" "system" "expired=$expired_count limit_violations=$limit_violations"
    msg_bar
    echo -ne "${cor[pink]}$(fun_trans 'Presione Enter para continuar')${cor[reset]}"
    read
}

