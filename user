# -------------------- CONFIGURACIÓN --------------------
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
TRANSLATOR_PY="$SCRIPT_DIR/translator.py"
LOG_FILE="/var/log/user_manager.log"
CONFIG_DIR="/etc/vps-barba"
BACKUP_DIR="/root/backups_users"
SCPdir="/"
MyPID=".pid-adm"
MyTIME="time-adm"
USRdatabase="ADMuser"
VERIFY_PID_FILE="/tmp/vps_barba_verify.pid"

mkdir -p "$CONFIG_DIR" "$BACKUP_DIR" 2>/dev/null

[[ -e .${MyPID} ]] && source .${MyPID} || touch .${MyPID}
[[ -e ${MyTIME} ]] && source .${MyTIME} || touch .${MyTIME}
[[ ! -e .${USRdatabase} ]] && touch .${USRdatabase}
sort .${USRdatabase} | uniq > .${USRdatabase}tmp 2>/dev/null
mv -f .${USRdatabase}tmp .${USRdatabase} 2>/dev/null

