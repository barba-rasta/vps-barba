    msg_bar
    echo -e "${cor[yellow]}$(fun_trans 'Formato: usuario|contraseña|fecha_exp|límite')${cor[reset]}"
    msg_bar
    local file_path
    while [[ ! -f "$file_path" ]]; do
        echo -ne "${cor[yellow]}➤ $(fun_trans 'Ruta del archivo'): ${cor[reset]}"
        read file_path
        [[ ! -f "$file_path" ]] && echo -e "${cor[red]}✘ $(fun_trans 'Archivo no encontrado')${cor[reset]}"
    done
    msg_bar
    echo -ne "${cor[yellow]}➤ $(fun_trans 'Sobrescribir existentes')? [S/N]: ${cor[reset]}"
    read overwrite
    local success=0 failed=0 total=0
    while IFS='|' read -r user pass date_exp limit; do
        [[ -z "$user" || "$user" =~ ^#.*$ ]] && continue
        ((total++))
        echo -ne "${cor[yellow]}➤ $(fun_trans 'Procesando') $user... ${cor[reset]}"
        if id "$user" &>/dev/null; then
            if [[ "$overwrite" =~ ^[sS]$ ]]; then
                userdel --force "$user" 2>/dev/null
            else
                echo -e "${cor[orange]}⏭ $(fun_trans 'Saltado')${cor[reset]}"
                continue
            fi
        fi
        local now_sec=$(date +%s)
        local exp_sec=$(date +%s --date="$date_exp" 2>/dev/null)
        if [[ -z "$exp_sec" || "$exp_sec" -le "$now_sec" ]]; then
            local days=30
        else
            local days=$(( (exp_sec - now_sec) / 86400 ))
        fi
        if add_user "$user" "$pass" "$days" "$limit" 2>/dev/null; then
            echo -e "${cor[green]}✔ OK${cor[reset]}"; ((success++))
        else
            echo -e "${cor[red]}✘ FAIL${cor[reset]}"; ((failed++))
        fi
    done < "$file_path"
    msg_bar
    echo -e "${cor[cyan]}╔═══════════════════════════════════════════╗${cor[reset]}"
    echo -e "${cor[cyan]}║      $(fun_trans 'RESUMEN DE IMPORTACIÓN')        ║${cor[reset]}"
