# Función para restaurar backup
restore_users() {
    local backup_file="$1"
    echo -e "${cor[yellow]}$(fun_trans 'Restaurando usuarios desde') $backup_file${cor[reset]}"
    msg_bar
    
    local success=0
    local failed=0
    local total=0
    
    while IFS='|' read -r user pass date_exp limit; do
        [[ -z "$user" ]] && continue
        total=$((total + 1))
        echo -ne "${cor[yellow]}➤ $(fun_trans 'Restaurando') $user... ${cor[reset]}"
        
        # Calcular días restantes
        local now_sec=$(date +%s)
        local exp_sec=$(date +%s --date="$date_exp" 2>/dev/null)
        if [[ -z "$exp_sec" ]] || [[ "$exp_sec" -le "$now_sec" ]]; then
            local days=30
        else
            local days=$((($exp_sec - $now_sec) / 86400))
        fi
        
        if add_user "$user" "$pass" "$days" "$limit" 2>/dev/null; then
            echo -e "${cor[green]}✔ OK${cor[reset]}"
            success=$((success + 1))
        else
            echo -e "${cor[red]}✘ FAIL${cor[reset]}"
            failed=$((failed + 1))
        fi
    done < "$backup_file"
    
    msg_bar
    echo -e "${cor[cyan]}╔═══════════════════════════════════════════╗${cor[reset]}"
    echo -e "${cor[cyan]}║      $(fun_trans 'RESUMEN DE RESTAURACIÓN')        ║${cor[reset]}"
    echo -e "${cor[cyan]}╚═══════════════════════════════════════════╝${cor[reset]}"
    echo -e "${cor[yellow]}➤ $(fun_trans 'Total'): ${cor[green]}$total${cor[reset]}"
    echo -e "${cor[yellow]}➤ $(fun_trans 'Éxitos'): ${cor[green]}$success${cor[reset]}"
    echo -e "${cor[yellow]}➤ $(fun_trans 'Fallos'): ${cor[red]}$failed${cor[reset]}"
    log_user_action "BACKUP_RESTORE" "batch" "total=$total success=$success failed=$failed"
}

