# -------------------- FUNCIONES AUXILIARES --------------------
log_message() {
    local level="$1"; local msg="$2"
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] [$level] $msg" >> "$LOG_FILE"
}

fun_trans() {
    local texto="$1"
    if [[ -f "$TRANSLATOR_PY" ]]; then
        python3 "$TRANSLATOR_PY" traducir "$texto" 2>/dev/null || echo "$texto"
    else
        echo "$texto"
    fi
}

msg_bar() { echo -e "$barra"; }
msg_title() { echo -e "$titulo_barra"; }

# -------------------- VALIDACIONES --------------------
validate_username() {
    local u="$1"
    [[ -z "$u" ]] && { echo "USERNAME_EMPTY"; return 1; }
    [[ ${#u} -lt 4 ]] && { echo "USERNAME_TOO_SHORT"; return 1; }
    [[ ${#u} -gt 24 ]] && { echo "USERNAME_TOO_LONG"; return 1; }
    [[ "$u" =~ [^a-zA-Z0-9_.-] ]] && { echo "USERNAME_INVALID_CHARS"; return 1; }
    grep -q "^$u:" /etc/passwd 2>/dev/null && { echo "USERNAME_EXISTS"; return 1; }
    echo "VALID"; return 0
}

validate_password() {
    local p="$1"
    [[ -z "$p" ]] && { echo "PASSWORD_EMPTY"; return 1; }
    [[ ${#p} -lt 6 ]] && { echo "PASSWORD_TOO_SHORT"; return 1; }
    [[ ${#p} -gt 30 ]] && { echo "PASSWORD_TOO_LONG"; return 1; }
    [[ ! "$p" =~ [A-Z] || ! "$p" =~ [a-z] || ! "$p" =~ [0-9] ]] && { echo "PASSWORD_WEAK"; return 1; }
    echo "VALID"; return 0
}

validate_days() {
    local d="$1"
    [[ -z "$d" ]] && { echo "DAYS_EMPTY"; return 1; }
    [[ ! "$d" =~ ^[0-9]+$ ]] && { echo "DAYS_INVALID"; return 1; }
    [[ "$d" -lt 1 ]] && { echo "DAYS_TOO_LOW"; return 1; }
    [[ "$d" -gt 365 ]] && { echo "DAYS_TOO_HIGH"; return 1; }
    echo "VALID"; return 0
}

validate_limit() {
    local l="$1"
    [[ -z "$l" ]] && { echo "LIMIT_EMPTY"; return 1; }
    [[ ! "$l" =~ ^[0-9]+$ ]] && { echo "LIMIT_INVALID"; return 1; }
    [[ "$l" -lt 1 ]] && { echo "LIMIT_TOO_LOW"; return 1; }
    [[ "$l" -gt 999 ]] && { echo "LIMIT_TOO_HIGH"; return 1; }
    echo "VALID"; return 0
}

show_error() {
    local code="$1"
    local msg
    case "$code" in
        "USERNAME_EMPTY") msg="$(fun_trans 'El nombre de usuario no puede estar vacío')" ;;
        "USERNAME_TOO_SHORT") msg="$(fun_trans 'El nombre de usuario debe tener al menos 4 caracteres')" ;;
        "USERNAME_TOO_LONG") msg="$(fun_trans 'El nombre de usuario no puede exceder 24 caracteres')" ;;
        "USERNAME_INVALID_CHARS") msg="$(fun_trans 'El nombre de usuario contiene caracteres inválidos')" ;;
        "USERNAME_EXISTS") msg="$(fun_trans 'El usuario ya existe en el sistema')" ;;
        "PASSWORD_EMPTY") msg="$(fun_trans 'La contraseña no puede estar vacía')" ;;
        "PASSWORD_TOO_SHORT") msg="$(fun_trans 'La contraseña debe tener al menos 6 caracteres')" ;;
        "PASSWORD_TOO_LONG") msg="$(fun_trans 'La contraseña no puede exceder 30 caracteres')" ;;
        "PASSWORD_WEAK") msg="$(fun_trans 'La contraseña debe contener mayúsculas, minúsculas y números')" ;;
        "DAYS_EMPTY") msg="$(fun_trans 'La duración no puede estar vacía')" ;;
        "DAYS_INVALID") msg="$(fun_trans 'La duración debe ser un número válido')" ;;
        "DAYS_TOO_LOW") msg="$(fun_trans 'La duración mínima es 1 día')" ;;
        "DAYS_TOO_HIGH") msg="$(fun_trans 'La duración máxima es de 365 días')" ;;
        "LIMIT_EMPTY") msg="$(fun_trans 'El límite no puede estar vacío')" ;;
        "LIMIT_INVALID") msg="$(fun_trans 'El límite debe ser un número válido')" ;;
        "LIMIT_TOO_LOW") msg="$(fun_trans 'El límite mínimo es 1')" ;;
        "LIMIT_TOO_HIGH") msg="$(fun_trans 'El límite máximo es 999')" ;;
        "USER_NOT_FOUND") msg="$(fun_trans 'Usuario no encontrado en el sistema')" ;;
        *) msg="$(fun_trans 'Error desconocido')" ;;
    esac
    echo -e "${cor[red]}✘ $msg${cor[reset]}"
    sleep 2
}

# -------------------- UTILIDADES --------------------
meu_ip() {
    local ip_file="/etc/MEUIPADM"
    if [[ -e "$ip_file" ]]; then
        cat "$ip_file"
    else
        local ip1=$(ip addr | grep 'inet' | grep -v inet6 | grep -vE '127\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}' | grep -o -E '[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}' | head -1)
        local ip2=$(wget -qO- ipv4.icanhazip.com 2>/dev/null)
        local ip=${ip2:-$ip1}
        echo "$ip" > "$ip_file" 2>/dev/null
        echo "$ip"
    fi
}

mostrar_usuarios() {
    awk -F: '$3 > 900 && $1 !~ /^(nobody|polkitd|system-|_)/ {print $1}' /etc/passwd 2>/dev/null | sort
}

get_user_info() {
    local user="$1"
    grep "^${user}|" "${USRdatabase}" 2>/dev/null | head -1
}

get_user_expiry() {
    local user="$1"
    chage -l "$user" 2>/dev/null | grep -i "Account expires" | awk -F: '{print $2}' | sed 's/^ //'
}

get_user_status() {
    local user="$1"
    local exp=$(get_user_expiry "$user")
    [[ -z "$exp" || "$exp" == "never" ]] && { echo "unlimited"; return; }
    local exp_sec=$(date +%s --date="$exp" 2>/dev/null)
    local now_sec=$(date +%s)
    [[ "$exp_sec" -lt "$now_sec" ]] && echo "expired" || echo "active"
}

get_days_remaining() {
    local user="$1"
    local exp=$(get_user_expiry "$user")
    [[ -z "$exp" || "$exp" == "never" ]] && { echo "∞"; return; }
    local exp_sec=$(date +%s --date="$exp" 2>/dev/null)
    local now_sec=$(date +%s)
    [[ "$exp_sec" -lt "$now_sec" ]] && echo "0" || echo $(( (exp_sec - now_sec) / 86400 ))
}

generate_secure_password() {
    local len=${1:-16}
    tr -dc 'A-Za-z0-9!@#$%^&*()_+=' </dev/urandom 2>/dev/null | head -c "$len" || openssl rand -base64 12 | tr -d '/+=' | head -c "$len"
}

get_user_connections() {
    local user="$1"
    local total=0
    total=$(( total + $(ps aux 2>/dev/null | grep -v grep | grep sshd | grep -w "$user" | grep -v root | wc -l) ))
    if command -v dropbear &>/dev/null; then
        total=$(( total + $(dropbear_pids 2>/dev/null | grep -w "$user" | wc -l) ))
    fi
    if [[ -f /etc/openvpn/openvpn-status.log ]]; then
        total=$(( total + $(grep -c "^${user}," /etc/openvpn/openvpn-status.log 2>/dev/null) ))
    fi
    echo "$total"
}

dropbear_pids() {
    local log="/var/log/auth.log"
    local loginsukses='Password auth succeeded'
    [[ ! -f "$log" ]] && return
    for port in $(ps aux 2>/dev/null | grep dropbear | grep -v grep | awk '{print $17}' | sort -u); do
        for pid in $(ps ax 2>/dev/null | grep dropbear | grep "$port" | awk '{print $1}'); do
            local login=$(grep "$pid" "$log" 2>/dev/null | grep "$loginsukses" | tail -1)
            if [[ -n "$login" ]]; then
                local user=$(echo "$login" | awk -F" " '{print $10}' | sed -r "s/'//g")
                [[ -n "$user" ]] && echo "$user"
            fi
        done
    done
}

# -------------------- GESTIÓN DE USUARIOS --------------------
add_user() {
    local username="$1" password="$2" days="$3" limit="$4"
    local valid
    valid=$(validate_username "$username") && [[ "$valid" != "VALID" ]] && return 1
    valid=$(validate_password "$password") && [[ "$valid" != "VALID" ]] && return 1
    valid=$(validate_days "$days") && [[ "$valid" != "VALID" ]] && return 1
    valid=$(validate_limit "$limit") && [[ "$valid" != "VALID" ]] && return 1

    local date_exp=$(date "+%F" -d "+ $days days")
    local valid_date=$(date '+%C%y-%m-%d' -d "+ $days days")
    useradd -M -s /bin/false "$username" -e "$valid_date" >/dev/null 2>&1 || return 1
    echo "$username:$password" | chpasswd 2>/dev/null || { userdel --force "$username" 2>/dev/null; return 1; }

    local temp_file=$(mktemp)
    grep -v "^${username}|" "${USRdatabase}" > "$temp_file" 2>/dev/null
    echo "${username}|${password}|${date_exp}|${limit}" >> "$temp_file"
    mv "$temp_file" "${USRdatabase}"
    log_message "INFO" "CREATE: $username days=$days limit=$limit expires=$date_exp"
    return 0
}

renew_user() {
    local username="$1" days="$2"
    id "$username" &>/dev/null || return 1
    local valid=$(validate_days "$days") && [[ "$valid" != "VALID" ]] && return 1
    local date_exp=$(date "+%F" -d "+ $days days")
    local valid_date=$(date '+%C%y-%m-%d' -d "+ $days days")
    chage -E "$valid_date" "$username" 2>/dev/null || return 1
    if grep -q "^${username}|" "${USRdatabase}" 2>/dev/null; then
        local temp_file=$(mktemp)
        local line=$(grep "^${username}|" "${USRdatabase}")
        local pass=$(echo "$line" | cut -d'|' -f2)
        local lim=$(echo "$line" | cut -d'|' -f4)
        grep -v "^${username}|" "${USRdatabase}" > "$temp_file"
        echo "${username}|${pass}|${date_exp}|${lim}" >> "$temp_file"
        mv "$temp_file" "${USRdatabase}"
    fi
    log_message "INFO" "RENEW: $username days=$days expires=$date_exp"
    return 0
}

remove_user() {
    local username="$1"
    id "$username" &>/dev/null || return 1
    pkill -u "$username" 2>/dev/null
    userdel --force "$username" 2>/dev/null || return 1
    if [[ -e "${USRdatabase}" ]]; then
        local temp_file=$(mktemp)
        grep -v "^${username}|" "${USRdatabase}" > "$temp_file"
        mv "$temp_file" "${USRdatabase}"
    fi
    rm -f "/home/$username" "/root/${username}.zip" "/root/${username}.ovpn" 2>/dev/null
    log_message "INFO" "REMOVE: $username"
    return 0
}

edit_user() {
    local username="$1" password="$2" days="$3" limit="$4"
    id "$username" &>/dev/null || return 1
    local valid=$(validate_password "$password") && [[ "$valid" != "VALID" ]] && return 1
    valid=$(validate_days "$days") && [[ "$valid" != "VALID" ]] && return 1
    valid=$(validate_limit "$limit") && [[ "$valid" != "VALID" ]] && return 1

    local date_exp=$(date "+%F" -d "+ $days days")
    local valid_date=$(date '+%C%y-%m-%d' -d "+ $days days")
    echo "$username:$password" | chpasswd 2>/dev/null || return 1
    chage -E "$valid_date" "$username" 2>/dev/null || return 1
    if [[ -e "${USRdatabase}" ]]; then
        local temp_file=$(mktemp)
        grep -v "^${username}|" "${USRdatabase}" > "$temp_file"
        echo "${username}|${password}|${date_exp}|${limit}" >> "$temp_file"
        mv "$temp_file" "${USRdatabase}"
    fi
    log_message "INFO" "EDIT: $username days=$days limit=$limit expires=$date_exp"
    return 0
}

# -------------------- VERIFICACIÓN EN SEGUNDO PLANO (mejorada) --------------------
verif_fun() {
    declare -A TIMEUS
    while true; do
        sleep 5
        if [[ -e ${MyTIME} ]]; then source ${MyTIME}; fi
        local TimeNOW=$(date +%s)
        local expired_count=0

        while read user; do
            local DataUser=$(get_user_expiry "$user")
            [[ -z "$DataUser" || "$DataUser" == "never" ]] && continue
            local DataSEC=$(date +%s --date="$DataUser" 2>/dev/null)
            if [[ "$DataSEC" -lt "$TimeNOW" ]]; then
                usermod -L "$user" 2>/dev/null
                ((expired_count++))
            fi
        done <<< "$(mostrar_usuarios)"

        while read user; do
            id "$user" &>/dev/null || continue
            local TotalPID=$(get_user_connections "$user")
            if [[ "$TotalPID" -eq 0 ]]; then
                usermod -U "$user" 2>/dev/null
                continue
            fi
            [[ -z "${TIMEUS[$user]}" ]] && TIMEUS[$user]=0
            [[ ! "${TIMEUS[$user]}" =~ ^[0-9]+$ ]] && TIMEUS[$user]=0
            TIMEUS[$user]=$((5 + ${TIMEUS[$user]}))
            local temp_time=$(mktemp)
            grep -v "^TIMEUS\[$user\]=" "$MyTIME" 2>/dev/null > "$temp_time"
            echo "TIMEUS[$user]='${TIMEUS[$user]}'" >> "$temp_time"
            mv "$temp_time" "$MyTIME"

            local line=$(get_user_info "$user")
            local limit=$(echo "$line" | cut -d'|' -f4)
            [[ -z "$limit" || ! "$limit" =~ ^[0-9]+$ ]] && continue
            if [[ "$TotalPID" -le "$limit" ]]; then
                usermod -U "$user" 2>/dev/null
            else
                local kill_count=$((TotalPID - limit))
                local pids=$(ps aux 2>/dev/null | grep -v grep | grep -E "(sshd|dropbear|openvpn)" | grep -w "$user" | awk '{print $2}' | tail -n "$kill_count")
                for pid in $pids; do kill -9 "$pid" 2>/dev/null; done
                usermod -L "$user" 2>/dev/null
            fi
        done <<< "$(mostrar_usuarios)"

        echo "$expired_count" > "${SCPdir}/USRexpired" 2>/dev/null
        echo "$(ps aux 2>/dev/null | grep -E "(sshd|dropbear|openvpn)" | grep -v grep | awk '{print $1}' | sort -u | wc -l)" > "${SCPdir}/USRonlines" 2>/dev/null

        if [[ $expired_count -gt 0 ]]; then
            echo "$(date '+%Y-%m-%d %H:%M:%S') - Expired: $expired_count" >> "/var/log/expired_users.log"
        fi
        if [[ $(wc -l < "$LOG_FILE" 2>/dev/null) -gt 10000 ]]; then
            tail -n 5000 "$LOG_FILE" > "${LOG_FILE}.tmp" && mv "${LOG_FILE}.tmp" "$LOG_FILE"
        fi
    done
}

# -------------------- CONTROL DE PROCESO DE VERIFICACIÓN --------------------
start_verification() {
    if [[ -f "$VERIFY_PID_FILE" ]] && kill -0 "$(cat "$VERIFY_PID_FILE")" 2>/dev/null; then
        return 0 # ya está corriendo
    fi
    rm -f "$VERIFY_PID_FILE"
    nohup bash -c "$(declare -f verif_fun); verif_fun" >/dev/null 2>&1 &
    echo $! > "$VERIFY_PID_FILE"
    sleep 1
    if kill -0 "$(cat "$VERIFY_PID_FILE")" 2>/dev/null; then
        log_message "INFO" "Verification started (PID: $(cat "$VERIFY_PID_FILE"))"
        return 0
    else
        rm -f "$VERIFY_PID_FILE"
        return 1
    fi
}

stop_verification() {
    if [[ -f "$VERIFY_PID_FILE" ]]; then
        local pid=$(cat "$VERIFY_PID_FILE")
        if kill -0 "$pid" 2>/dev/null; then
            kill -9 "$pid" 2>/dev/null
            log_message "INFO" "Verification stopped (PID: $pid)"
        fi
        rm -f "$VERIFY_PID_FILE"
    fi
    # limpiar estados
    for USR in $(mostrar_usuarios); do
        usermod -U "$USR" 2>/dev/null
    done
    [[ -e USRonlines ]] && rm USRonlines 2>/dev/null
    [[ -e USRexpired ]] && rm USRexpired 2>/dev/null
}

is_verification_running() {
    [[ -f "$VERIFY_PID_FILE" ]] && kill -0 "$(cat "$VERIFY_PID_FILE")" 2>/dev/null
}

# -------------------- FUNCIONES DEL MENÚ (con colores corregidos) --------------------
new_user() {
    clear
    echo -e "${cor[cyan]}╔════════════════════════════════════════════════════╗${cor[reset]}"
    echo -e "${cor[cyan]}║         $(fun_trans 'CREAR NUEVO USUARIO')                ║${cor[reset]}"
    echo -e "${cor[cyan]}╚════════════════════════════════════════════════════╝${cor[reset]}"
    msg_bar
    local usuarios_ativos=($(mostrar_usuarios))
    if [[ ${#usuarios_ativos[@]} -gt 0 ]]; then
        echo -e "${cor[yellow]}$(fun_trans 'Usuarios existentes')${cor[reset]}"
        msg_bar
        for us in "${usuarios_ativos[@]}"; do echo -e "${cor[green]}•${cor[reset]} ${cor[white]}$us${cor[reset]}"; done
        msg_bar
    fi
    local username password days limit
    while true; do
        echo -ne "${cor[yellow]}➤ $(fun_trans 'Nombre del nuevo usuario'): ${cor[reset]}"
        read username
        local valid=$(validate_username "$username")
        [[ "$valid" == "VALID" ]] && break || show_error "$valid"
    done
    while true; do
        echo -ne "${cor[yellow]}➤ $(fun_trans 'Contraseña'): ${cor[reset]}"
        read -s password; echo
        local valid=$(validate_password "$password")
        [[ "$valid" == "VALID" ]] && break || show_error "$valid"
    done
    while true; do
        echo -ne "${cor[yellow]}➤ $(fun_trans 'Días de duración'): ${cor[reset]}"
        read days
        local valid=$(validate_days "$days")
        [[ "$valid" == "VALID" ]] && break || show_error "$valid"
    done
    while true; do
        echo -ne "${cor[yellow]}➤ $(fun_trans 'Límite de conexión'): ${cor[reset]}"
        read limit
        local valid=$(validate_limit "$limit")
        [[ "$valid" == "VALID" ]] && break || show_error "$valid"
    done
    msg_bar
    echo -e "${cor[cyan]}╔═══════════════════════════════════════════╗${cor[reset]}"
    echo -e "${cor[cyan]}║      $(fun_trans 'RESUMEN DEL USUARIO')           ║${cor[reset]}"
    echo -e "${cor[cyan]}╚═══════════════════════════════════════════╝${cor[reset]}"
    echo -e "${cor[yellow]}➤ $(fun_trans 'IP'): ${cor[green]}$(meu_ip)${cor[reset]}"
    echo -e "${cor[yellow]}➤ $(fun_trans 'Usuario'): ${cor[green]}$username${cor[reset]}"
    echo -e "${cor[yellow]}➤ $(fun_trans 'Contraseña'): ${cor[green]}$password${cor[reset]}"
    echo -e "${cor[yellow]}➤ $(fun_trans 'Días'): ${cor[green]}$days${cor[reset]}"
    echo -e "${cor[yellow]}➤ $(fun_trans 'Expira'): ${cor[green]}$(date "+%F" -d "+ $days days")${cor[reset]}"
    echo -e "${cor[yellow]}➤ $(fun_trans 'Límite'): ${cor[green]}$limit${cor[reset]}"
    msg_bar
    echo -ne "${cor[yellow]}$(fun_trans '¿Crear usuario?') [S/N]: ${cor[reset]}"
    read confirm
    if [[ "$confirm" =~ ^[sS]$ ]]; then
        if add_user "$username" "$password" "$days" "$limit"; then
            echo -e "${cor[green]}✔ $(fun_trans 'Usuario creado con éxito')${cor[reset]}"
            [[ -f /etc/openvpn/openvpn-status.log ]] && newclient "$username" "$password" 2>/dev/null
        else
            echo -e "${cor[red]}✘ $(fun_trans 'Error al crear el usuario')${cor[reset]}"
        fi
    else
        echo -e "${cor[yellow]}⏭ $(fun_trans 'Creación cancelada')${cor[reset]}"
    fi
    msg_bar; echo -ne "${cor[pink]}$(fun_trans 'Presione Enter')${cor[reset]}"; read
}

remove_user_interactive() {
    clear
    echo -e "${cor[cyan]}╔════════════════════════════════════════════════════╗${cor[reset]}"
    echo -e "${cor[cyan]}║         $(fun_trans 'ELIMINAR USUARIO')                ║${cor[reset]}"
    echo -e "${cor[cyan]}╚════════════════════════════════════════════════════╝${cor[reset]}"
    msg_bar
    local usuarios_ativos=($(mostrar_usuarios))
    [[ ${#usuarios_ativos[@]} -eq 0 ]] && { echo -e "${cor[red]}✘ $(fun_trans 'No hay usuarios')${cor[reset]}"; msg_bar; echo -ne "${cor[pink]}$(fun_trans 'Presione Enter')${cor[reset]}"; read; return 1; }
    echo -e "${cor[yellow]}$(fun_trans 'Usuarios disponibles')${cor[reset]}"
    msg_bar
    local i=0
    for us in "${usuarios_ativos[@]}"; do
        local status=$(get_user_status "$us")
        local icon=""
        case "$status" in active) icon="${cor[green]}●${cor[reset]}" ;; expired) icon="${cor[red]}●${cor[reset]}" ;; unlimited) icon="${cor[purple]}●${cor[reset]}" ;; esac
        echo -e "${cor[green]}[$i]${cor[reset]} $us $icon"
        ((i++))
    done
    msg_bar
    local selection
    while [[ -z "$selection" ]]; do
        echo -ne "${cor[yellow]}➤ $(fun_trans 'Seleccione (nombre o número)'): ${cor[reset]}"
        read selection
    done
    local username=""
    if [[ "$selection" =~ ^[0-9]+$ ]] && [[ "$selection" -lt ${#usuarios_ativos[@]} ]]; then
        username="${usuarios_ativos[$selection]}"
    else
        username="$selection"
    fi
    id "$username" &>/dev/null || { echo -e "${cor[red]}✘ $(fun_trans 'Usuario no encontrado')${cor[reset]}"; msg_bar; read -p "Enter"; return 1; }
    echo -ne "${cor[red]}$(fun_trans '¿Eliminar a') $username? [S/N]: ${cor[reset]}"
    read confirm
    if [[ "$confirm" =~ ^[sS]$ ]]; then
        remove_user "$username" && echo -e "${cor[red]}✘ $(fun_trans 'Eliminado') $username${cor[reset]}" || echo -e "${cor[red]}✘ $(fun_trans 'Error')${cor[reset]}"
    else
        echo -e "${cor[yellow]}⏭ $(fun_trans 'Cancelado')${cor[reset]}"
    fi
    msg_bar; echo -ne "${cor[pink]}$(fun_trans 'Presione Enter')${cor[reset]}"; read
}

renew_user_interactive() {
    clear
