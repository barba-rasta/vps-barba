    case "$error_code" in
        "USERNAME_EMPTY") echo -e "${cor[red]}✘ $(fun_trans 'El nombre de usuario no puede estar vacío')${cor[reset]}" ;;
        "USERNAME_TOO_SHORT") echo -e "${cor[red]}✘ $(fun_trans 'El nombre de usuario debe tener al menos 4 caracteres')${cor[reset]}" ;;
        "USERNAME_TOO_LONG") echo -e "${cor[red]}✘ $(fun_trans 'El nombre de usuario no puede exceder 24 caracteres')${cor[reset]}" ;;
        "USERNAME_INVALID_CHARS") echo -e "${cor[red]}✘ $(fun_trans 'El nombre de usuario contiene caracteres inválidos')${cor[reset]}" ;;
        "USERNAME_EXISTS") echo -e "${cor[red]}✘ $(fun_trans 'El usuario ya existe en el sistema')${cor[reset]}" ;;
        "PASSWORD_EMPTY") echo -e "${cor[red]}✘ $(fun_trans 'La contraseña no puede estar vacía')${cor[reset]}" ;;
        "PASSWORD_TOO_SHORT") echo -e "${cor[red]}✘ $(fun_trans 'La contraseña debe tener al menos 6 caracteres')${cor[reset]}" ;;
        "PASSWORD_TOO_LONG") echo -e "${cor[red]}✘ $(fun_trans 'La contraseña no puede exceder 30 caracteres')${cor[reset]}" ;;
        "PASSWORD_WEAK") echo -e "${cor[red]}✘ $(fun_trans 'La contraseña debe contener mayúsculas, minúsculas y números')${cor[reset]}" ;;
        "DAYS_EMPTY") echo -e "${cor[red]}✘ $(fun_trans 'La duración no puede estar vacía')${cor[reset]}" ;;
        "DAYS_INVALID") echo -e "${cor[red]}✘ $(fun_trans 'La duración debe ser un número válido')${cor[reset]}" ;;
        "DAYS_TOO_LOW") echo -e "${cor[red]}✘ $(fun_trans 'La duración mínima es 1 día')${cor[reset]}" ;;
        "DAYS_TOO_HIGH") echo -e "${cor[red]}✘ $(fun_trans 'La duración máxima es de 365 días')${cor[reset]}" ;;
        "LIMIT_EMPTY") echo -e "${cor[red]}✘ $(fun_trans 'El límite no puede estar vacío')${cor[reset]}" ;;
        "LIMIT_INVALID") echo -e "${cor[red]}✘ $(fun_trans 'El límite debe ser un número válido')${cor[reset]}" ;;
        "LIMIT_TOO_LOW") echo -e "${cor[red]}✘ $(fun_trans 'El límite mínimo es 1')${cor[reset]}" ;;
        "LIMIT_TOO_HIGH") echo -e "${cor[red]}✘ $(fun_trans 'El límite máximo es 999')${cor[reset]}" ;;
        "USER_NOT_FOUND") echo -e "${cor[red]}✘ $(fun_trans 'Usuario no encontrado en el sistema')${cor[reset]}" ;;
        *) echo -e "${cor[red]}✘ $(fun_trans 'Error desconocido')${cor[reset]}" ;;
    esac
    sleep 2
}

# ==============================================
# FUNCIONES DE UTILIDAD MEJORADAS
# ==============================================

meu_ip() {
    local ip_file="/etc/MEUIPADM"
    if [[ -e "$ip_file" ]]; then
        cat "$ip_file"
    else
        local ip1=$(ip addr | grep 'inet' | grep -v inet6 | grep -vE '127\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}' | grep -o -E '[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}' | head -1)
        local ip2=$(wget -qO- ipv4.icanhazip.com 2>/dev/null)
        local ip=${ip2:-$ip1}
        echo "$ip" > "$ip_file" 2>/dev/null
        echo "$ip"
    fi
}

mostrar_usuarios() {
    awk -F: '$3 > 900 && $1 !~ /^(nobody|polkitd|system-|_)/ {print $1}' /etc/passwd 2>/dev/null | sort
}

get_user_info() {
    local user="$1"
    if [[ -e "${USRdatabase}" ]] && grep -q "^${user}|" "${USRdatabase}"; then
        grep "^${user}|" "${USRdatabase}" | head -1
    else
        echo ""
    fi
}

get_user_expiry() {
    local user="$1"
    chage -l "$user" 2>/dev/null | grep -i "Account expires" | awk -F: '{print $2}' | sed 's/^ //'
}

get_user_status() {
    local user="$1"
    local expiry=$(get_user_expiry "$user")
    if [[ -z "$expiry" ]] || [[ "$expiry" == "never" ]]; then
        echo "unlimited"
    else
        local exp_sec=$(date +%s --date="$expiry" 2>/dev/null)
        local now_sec=$(date +%s)
        if [[ "$exp_sec" -lt "$now_sec" ]]; then
            echo "expired"
        else
            echo "active"
        fi
    fi
}

get_days_remaining() {
    local user="$1"
    local expiry=$(get_user_expiry "$user")
    if [[ -z "$expiry" ]] || [[ "$expiry" == "never" ]]; then
        echo "∞"
    else
        local exp_sec=$(date +%s --date="$expiry" 2>/dev/null)
        local now_sec=$(date +%s)
        if [[ "$exp_sec" -lt "$now_sec" ]]; then
            echo "0"
        else
            echo $((($exp_sec - $now_sec) / 86400))
        fi
    fi
}

generate_secure_password() {
    local length=${1:-12}
    tr -dc 'A-Za-z0-9!@#$%^&*()_+' </dev/urandom 2>/dev/null | head -c "$length" || openssl rand -base64 12 | tr -d '/+=' | head -c "$length"
}

# ==============================================
# FUNCIONES DE GESTIÓN DE USUARIOS MEJORADAS
# ==============================================

add_user() {
    local username="$1"
    local password="$2"
    local days="$3"
    local limit="$4"
    
    # Validar entrada
    local valid=$(validate_username "$username")
    [[ "$valid" != "VALID" ]] && return 1
    valid=$(validate_password "$password")
    [[ "$valid" != "VALID" ]] && return 1
    valid=$(validate_days "$days")
    [[ "$valid" != "VALID" ]] && return 1
    valid=$(validate_limit "$limit")
    [[ "$valid" != "VALID" ]] && return 1
    
    # Calcular fecha de expiración
    local date_exp=$(date "+%F" -d "+ $days days")
    local valid_date=$(date '+%C%y-%m-%d' -d "+ $days days")
    
    # Crear usuario
    useradd -M -s /bin/false "$username" -e "$valid_date" > /dev/null 2>&1 || return 1
    echo "$username:$password" | chpasswd 2>/dev/null || {
        userdel --force "$username" 2>/dev/null
        return 1
    }
    
    # Guardar en base de datos
    local temp_file=$(mktemp)
    if [[ -e "${USRdatabase}" ]]; then
        grep -v "^${username}|" "${USRdatabase}" > "$temp_file"
    fi
    echo "${username}|${password}|${date_exp}|${limit}" >> "$temp_file"
    mv "$temp_file" "${USRdatabase}"
    
    log_user_action "CREATE" "$username" "days=$days limit=$limit expires=$date_exp"
    return 0
}

renew_user() {
    local username="$1"
    local days="$2"
    
    if ! id "$username" &>/dev/null; then
        return 1
    fi
    
    local valid=$(validate_days "$days")
    [[ "$valid" != "VALID" ]] && return 1
    
    local date_exp=$(date "+%F" -d "+ $days days")
    local valid_date=$(date '+%C%y-%m-%d' -d "+ $days days")
    
    chage -E "$valid_date" "$username" 2>/dev/null || return 1
    
    if [[ -e "${USRdatabase}" ]] && grep -q "^${username}|" "${USRdatabase}"; then
        local temp_file=$(mktemp)
        local user_line=$(grep "^${username}|" "${USRdatabase}")
        local password=$(echo "$user_line" | cut -d'|' -f2)
        local limit=$(echo "$user_line" | cut -d'|' -f4)
        grep -v "^${username}|" "${USRdatabase}" > "$temp_file"
        echo "${username}|${password}|${date_exp}|${limit}" >> "$temp_file"
        mv "$temp_file" "${USRdatabase}"
    fi
    
    log_user_action "RENEW" "$username" "days=$days expires=$date_exp"
    return 0
}

edit_user() {
    local username="$1"
    local new_password="$2"
    local days="$3"
    local limit="$4"
    
    if ! id "$username" &>/dev/null; then
        return 1
    fi
    
    local valid=$(validate_password "$new_password")
    [[ "$valid" != "VALID" ]] && return 1
    valid=$(validate_days "$days")
    [[ "$valid" != "VALID" ]] && return 1
    valid=$(validate_limit "$limit")
    [[ "$valid" != "VALID" ]] && return 1
    
    local date_exp=$(date "+%F" -d "+ $days days")
    local valid_date=$(date '+%C%y-%m-%d' -d "+ $days days")
    
    echo "$username:$new_password" | chpasswd 2>/dev/null || return 1
    chage -E "$valid_date" "$username" 2>/dev/null || return 1
    
    if [[ -e "${USRdatabase}" ]]; then
        local temp_file=$(mktemp)
        grep -v "^${username}|" "${USRdatabase}" > "$temp_file"
        echo "${username}|${new_password}|${date_exp}|${limit}" >> "$temp_file"
        mv "$temp_file" "${USRdatabase}"
    fi
    
    log_user_action "EDIT" "$username" "days=$days limit=$limit expires=$date_exp"
    return 0
}

remove_user() {
    local username="$1"
    
    if ! id "$username" &>/dev/null; then
        return 1
    fi
    
    # Matar procesos activos del usuario
    pkill -u "$username" 2>/dev/null
    
    # Eliminar usuario
    userdel --force "$username" 2>/dev/null || return 1
    
    # Eliminar de la base de datos
    if [[ -e "${USRdatabase}" ]]; then
        local temp_file=$(mktemp)
        grep -v "^${username}|" "${USRdatabase}" > "$temp_file"
        mv "$temp_file" "${USRdatabase}"
    fi
    
    # Eliminar archivos de configuración
    rm -f "/home/$username" 2>/dev/null
    rm -f "/root/${username}.zip" 2>/dev/null
    rm -f "/root/${username}.ovpn" 2>/dev/null
    
    log_user_action "REMOVE" "$username" "user removed"
    return 0
}

# ==============================================
# FUNCIONES DE MONITOREO MEJORADAS
# ==============================================

get_user_connections() {
    local username="$1"
    local total=0
    
    # SSH connections
    if command -v sshd &>/dev/null; then
        total=$((total + $(ps aux 2>/dev/null | grep -v grep | grep sshd | grep -w "$username" | grep -v root | wc -l)))
    fi
    
    # Dropbear connections
    if command -v dropbear &>/dev/null; then
        total=$((total + $(dropbear_pids 2>/dev/null | grep -w "$username" | wc -l)))
    fi
    
    # OpenVPN connections
    if [[ -f /etc/openvpn/openvpn-status.log ]]; then
        total=$((total + $(grep -c "^${username}," /etc/openvpn/openvpn-status.log 2>/dev/null)))
    fi
    
    echo "$total"
}

get_all_user_stats() {
    local stats=""
    while read user; do
        local connections=$(get_user_connections "$user")
        local status=$(get_user_status "$user")
        local days_left=$(get_days_remaining "$user")
        local info=$(get_user_info "$user")
        local limit=$(echo "$info" | cut -d'|' -f4)
        [[ -z "$limit" ]] && limit="?"
        stats="${stats}${user}|${connections}|${limit}|${status}|${days_left}\n"
    done <<< "$(mostrar_usuarios)"
    echo -e "$stats"
}

# ==============================================
# FUNCIONES DE DROPBEAR Y OPENVPN
# ==============================================

dropbear_pids() {
    local log="/var/log/auth.log"
    local loginsukses='Password auth succeeded'
    [[ ! -f "$log" ]] && return
    
    for port in $(ps aux 2>/dev/null | grep dropbear | grep -v grep | awk '{print $17}' | sort -u); do
        for pid in $(ps ax 2>/dev/null | grep dropbear | grep "$port" | awk '{print $1}'); do
            local login=$(grep "$pid" "$log" 2>/dev/null | grep "$loginsukses" | tail -1)
            if [[ -n "$login" ]]; then
                local user=$(echo "$login" | awk -F" " '{print $10}' | sed -r "s/'//g")
                local waktu=$(echo "$login" | awk -F" " '{print $2"-"$1,$3}')
                [[ -n "$user" ]] && echo "$user|$pid|$waktu"
            fi
        done
    done
}

openvpn_pids() {
    local status_file="/etc/openvpn/openvpn-status.log"
    [[ ! -f "$status_file" ]] && return
    
    local users=$(mostrar_usuarios)
    for user in $users; do
        local count=$(grep -c "^${user}," "$status_file" 2>/dev/null)
        if [[ $count -gt 0 ]]; then
            echo "$user|$count"
        fi
    done
}

# ==============================================
# FUNCIONES DE SEGURIDAD MEJORADAS
# ==============================================

block_failed_attempts() {
    local user="$1"
    local max_attempts=5
    local block_time=300  # 5 minutos
    
    local attempt_file="/tmp/failed_${user}"
    local attempts=$(cat "$attempt_file" 2>/dev/null || echo 0)
    
    if [[ $attempts -ge $max_attempts ]]; then
        echo "$(date +%s)" > "/tmp/blocked_${user}"
        rm -f "$attempt_file"
        log_message "WARN" "Usuario $user bloqueado por intentos fallidos"
        return 1
    fi
    
    return 0
}

record_failed_attempt() {
    local user="$1"
    local attempt_file="/tmp/failed_${user}"
    local attempts=$(cat "$attempt_file" 2>/dev/null || echo 0)
    echo $((attempts + 1)) > "$attempt_file"
    log_message "WARN" "Intento fallido de conexión para $user (${attempts}/5)"
}

