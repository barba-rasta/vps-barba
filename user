        local HOUR="${HOR}h:${MIN}m:${SEC}s"
        
        if [[ $TotalPID -gt 0 ]]; then
            local status="${cor[green]}● Conectado${cor[reset]}"
        else
            local status="${cor[red]}● Desconectado${cor[reset]}"
        fi
        
        printf "${cor[white]}%-20s ${cor[green]}%3s/${limit} ${cor[cyan]}%-15s ${cor[orange]}%s${cor[reset]}\n" \
            "$user" "$TotalPID" "$HOUR" "$status"
    done <<< "$(mostrar_usuarios)"
    
    msg_bar
    echo -ne "${cor[pink]}$(fun_trans 'Presione Enter para continuar')${cor[reset]}"
    read
}

