}

# ==============================================
# FUNCIONES DE VALIDACIÓN MEJORADAS
# ==============================================

validate_username() {
    local username="$1"
    if [[ -z "$username" ]]; then
        echo "USERNAME_EMPTY"
        return 1
    elif [[ "${#username}" -lt 4 ]]; then
        echo "USERNAME_TOO_SHORT"
        return 1
    elif [[ "${#username}" -gt 24 ]]; then
        echo "USERNAME_TOO_LONG"
        return 1
    elif [[ "$username" =~ [^a-zA-Z0-9_.-] ]]; then
        echo "USERNAME_INVALID_CHARS"
        return 1
    elif grep -q "^$username:" /etc/passwd 2>/dev/null; then
        echo "USERNAME_EXISTS"
        return 1
    fi
    echo "VALID"
    return 0
}

validate_password() {
    local password="$1"
    if [[ -z "$password" ]]; then
        echo "PASSWORD_EMPTY"
        return 1
    elif [[ "${#password}" -lt 6 ]]; then
        echo "PASSWORD_TOO_SHORT"
        return 1
    elif [[ "${#password}" -gt 30 ]]; then
        echo "PASSWORD_TOO_LONG"
        return 1
    elif [[ ! "$password" =~ [A-Z] ]] || [[ ! "$password" =~ [a-z] ]] || [[ ! "$password" =~ [0-9] ]]; then
        echo "PASSWORD_WEAK"
        return 1
    fi
    echo "VALID"
    return 0
}

validate_days() {
    local days="$1"
    if [[ -z "$days" ]]; then
        echo "DAYS_EMPTY"
        return 1
    elif [[ ! "$days" =~ ^[0-9]+$ ]]; then
        echo "DAYS_INVALID"
        return 1
    elif [[ "$days" -lt 1 ]]; then
        echo "DAYS_TOO_LOW"
        return 1
    elif [[ "$days" -gt 365 ]]; then
        echo "DAYS_TOO_HIGH"
        return 1
    fi
    echo "VALID"
    return 0
}

validate_limit() {
    local limit="$1"
    if [[ -z "$limit" ]]; then
        echo "LIMIT_EMPTY"
        return 1
    elif [[ ! "$limit" =~ ^[0-9]+$ ]]; then
        echo "LIMIT_INVALID"
        return 1
    elif [[ "$limit" -lt 1 ]]; then
        echo "LIMIT_TOO_LOW"
        return 1
    elif [[ "$limit" -gt 999 ]]; then
        echo "LIMIT_TOO_HIGH"
        return 1
    fi
    echo "VALID"
    return 0
}

# ==============================================
# FUNCIÓN DE MENSAJES DE ERROR MEJORADA
# ==============================================
show_error() {
